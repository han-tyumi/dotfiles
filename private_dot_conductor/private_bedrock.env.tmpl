{{- /* Bedrock config for Conductor's bundled Claude Code, in dotenv format.
       Point Conductor's Settings > Environment > "Add env file" at
       ~/.conductor/bedrock.env. The bearer token is read from the macOS Keychain
       (service "claude-code-bedrock", account "bearer") at apply time, so it never
       lands in the source tree. The lookup tolerates a missing item: a machine
       without the token renders only the comment below, leaving Conductor to fall
       back to whatever provider is configured in the app rather than an empty
       CLAUDE_CODE_USE_BEDROCK. Model IDs are the plain inference-profile form (no
       [1m] suffix, which is a Claude Code alias convention, not a Bedrock id). */ -}}
{{- $bedrockToken := output "sh" "-c" "security find-generic-password -s claude-code-bedrock -a bearer -w 2>/dev/null || true" | trim -}}
{{- if $bedrockToken }}
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK={{ $bedrockToken }}
ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-8
ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
{{- else }}
# No Bedrock token in the Keychain on this machine; Conductor uses its own
# configured provider instead.
{{- end }}
