// Zed settings for Windows — managed by chezmoi. Mirrors the macOS config at
// dot_config/zed/private_settings.json, with two intentional differences: the
// integrated terminal launches nushell directly (no login-zsh wrapper), and the
// macOS `language_models.bedrock` block is omitted (that path is for work machines
// on AWS Bedrock; this machine uses subscription auth via the claude-acp agent).
//
// Font: PragmataPro is a paid family (install it per-machine); every font key
// falls back to Iosevka Nerd Font Mono, so a machine without PragmataPro still
// gets a close, condensed coding face plus icon glyphs.
{
  "$schema": "zed://schemas/settings",

  // Appearance
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_family": "PragmataPro VF",
  "ui_font_fallbacks": ["Iosevka Nerd Font", "Consolas"],
  "ui_font_size": 16,
  "buffer_font_family": "PragmataPro VF Mono Liga",
  "buffer_font_fallbacks": ["Iosevka Nerd Font Mono", "Consolas"],
  "buffer_font_features": { "calt": true, "liga": true },
  "buffer_font_weight": 500,
  "buffer_font_size": 15,

  // Terminal — nushell is the interactive shell; byte-fidelity (no-ligature) font.
  "terminal": {
    "shell": {
      "program": "nu",
    },
    "font_family": "PragmataPro VF Mono",
    "font_fallbacks": ["Iosevka Nerd Font Mono", "Consolas"],
  },

  // Key Bindings
  "base_keymap": "VSCode",

  // Agent — the "Claude Agent" registry runs the local Claude Code CLI over ACP,
  // inheriting ~/.claude/settings.json (subscription auth on this machine).
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },

  // Extensions
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "nu": true,
  },
}
