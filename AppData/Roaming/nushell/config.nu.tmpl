# Nushell config for Windows — managed by chezmoi. Nushell is the interactive
# shell; PowerShell 7 stays available and carries the same activations.

$env.config.show_banner = false

# mise/starship/zoxide activations. Nushell resolves `source` at parse time, so
# these modules are generated on apply (from the tools' own `activate`/`init`
# output) and seeded as empty stubs — sourcing them here always parses.
source mise.nu
source starship.nu
source zoxide.nu

# fzf key bindings: Ctrl+R fuzzy history search, Ctrl+T fuzzy file insert.
$env.config.keybindings = ($env.config.keybindings | append [
  {
    name: fzf_history
    modifier: control
    keycode: char_r
    mode: [emacs vi_normal vi_insert]
    event: { send: executehostcommand, cmd: "commandline edit --replace (history | get command | uniq | reverse | str join (char newline) | fzf --scheme history --layout reverse --height 40% | str trim)" }
  }
  {
    name: fzf_file
    modifier: control
    keycode: char_t
    mode: [emacs vi_normal vi_insert]
    event: { send: executehostcommand, cmd: "commandline edit --insert (fzf --walker file,follow,hidden --walker-skip .git,node_modules,target --layout reverse --height 40% | str trim)" }
  }
])

# One-command sync, mirroring the Mac `apploi` (plain = do everything). With no
# flags it pulls, applies, and upgrades; each flag runs only that step:
#   apploi       pull + apply + upgrade winget packages + upgrade mise plugins/runtimes
#   apploi -c    config only: pull + apply, skip the upgrades (a quick sync)
#   apploi -w    upgrade winget packages only
#   apploi -m    upgrade mise plugins + runtimes (and regenerate the nu activations)
# Each step prints a line so a converged (no-op) run still confirms it ran.
def apploi [--chezmoi (-c), --winget (-w), --mise (-m)] {
  let do_all = (not ($chezmoi or $winget or $mise))
  let source = (^chezmoi source-path)

  if ($do_all or $chezmoi) {
    # A dirty tree (mid-edit of tracked files) skips the pull; a dirty submodule
    # does not, so the perpetually-dirty nvim submodule never blocks it.
    if (do { ^git -C $source diff --quiet --ignore-submodules=dirty HEAD } | complete).exit_code == 0 {
      print $"(ansi cyan)apploi(ansi reset): pulling dotfiles source..."
      if (do { ^git -C $source pull --ff-only --quiet } | complete).exit_code != 0 {
        print $"(ansi yellow)apploi(ansi reset): pull skipped — origin diverged; resync with: git fetch && git reset --hard origin/main"
      }
    } else {
      print $"(ansi cyan)apploi(ansi reset): local changes present — skipping pull"
    }
    # --keep-going so one failing target doesn't skip every later target.
    print $"(ansi cyan)apploi(ansi reset): applying dotfiles..."
    ^chezmoi apply --keep-going
  }

  if ($do_all or $winget) {
    print $"(ansi cyan)apploi(ansi reset): upgrading winget packages..."
    winget upgrade --all --silent --include-unknown --accept-package-agreements --accept-source-agreements --disable-interactivity
  }

  if ($do_all or $mise) {
    print $"(ansi cyan)apploi(ansi reset): upgrading mise plugins and runtimes..."
    mise plugins upgrade
    mise upgrade
    # Regenerate these activation modules against the upgraded tools.
    ^mise activate nu | save -f ($nu.default-config-dir | path join mise.nu)
    ^starship init nu | save -f ($nu.default-config-dir | path join starship.nu)
    ^zoxide init nushell | save -f ($nu.default-config-dir | path join zoxide.nu)
  }

  # Surface a WinUtil update if the pinned build is behind (best-effort, quiet when current).
  do -i { ^pwsh -NoProfile -ExecutionPolicy Bypass -File ($nu.home-dir | path join '.config' 'winutil' 'manage.ps1') }

  print $"(ansi green)apploi(ansi reset): done."
}

# Apply the captured WinUtil tweak config (manage.ps1 self-elevates with one UAC prompt).
def winutil-apply [] {
  ^pwsh -NoProfile -ExecutionPolicy Bypass -File ($nu.home-dir | path join '.config' 'winutil' 'manage.ps1') -Apply
}

# Enable the captured Windows optional features (.NET, media, OpenSSH, registry
# backup); enable-features.ps1 self-elevates with one UAC prompt.
def windows-features [] {
  ^powershell.exe -NoProfile -ExecutionPolicy Bypass -File ($nu.home-dir | path join '.config' 'windows' 'enable-features.ps1')
}
