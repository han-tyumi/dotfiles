# Nushell config for Windows — managed by chezmoi. Nushell is the interactive
# shell; PowerShell 7 stays available and carries the same activations.
#
# mise/starship/zoxide activations: nushell resolves `source` at PARSE time, so
# these files must already exist when this config is parsed. The
# run_onchange_after_30-nushell-activations provisioner generates them (the real
# activation when the tool is present, an empty placeholder otherwise), so the
# sources below are always safe and stay chezmoi-managed instead of hand-wired.
source mise.nu
source starship.nu
source zoxide.nu

$env.config.show_banner = false

# One-command sync, mirroring the Mac `apploi`:
#   apploi       converge to the declared dotfiles + package state
#   apploi -u    also upgrade winget packages and mise runtimes
def apploi [--upgrade (-u)] {
  chezmoi update --apply
  if $upgrade {
    winget upgrade --all --silent --include-unknown --accept-package-agreements --accept-source-agreements --disable-interactivity
    mise upgrade
  }
}
