# winget packages hash: {{ include "dot_config/winget/packages.json" | sha256sum }}
#
# Converge to the declared winget package set. `winget import` installs missing
# packages (it does NOT upgrade; that is what `apploi -u` does). Kept PowerShell
# 5.1-safe: on a fresh machine pwsh 7 is not installed yet, so chezmoi runs this
# under Windows PowerShell 5.1 on the first apply.
$manifest = Join-Path $env:USERPROFILE '.config\winget\packages.json'
if (-not (Test-Path $manifest)) {
  Write-Host "winget manifest not found at $manifest; skipping."
  return
}

# winget updates PATH in the registry but not this session; resolve it from its
# link dir when it is not yet on PATH.
$winget = (Get-Command winget -ErrorAction SilentlyContinue).Source
if (-not $winget) { $winget = Join-Path $env:LOCALAPPDATA 'Microsoft\WinGet\Links\winget.exe' }
if (-not (Test-Path $winget)) {
  Write-Warning "winget not found; install 'App Installer' from the Microsoft Store, then re-run."
  exit 1
}

& $winget import --import-file $manifest `
  --accept-package-agreements --accept-source-agreements `
  --ignore-unavailable --disable-interactivity
$importExit = $LASTEXITCODE

# Presence is the source of truth, not the import exit code. winget returns
# non-zero when a package is already installed but cannot be reinstalled - e.g. an
# app that is currently running (PersistentWindows) locks its own files - which is
# not a failure for an install-if-missing pass. And --ignore-unavailable silently
# skips a delisted or renamed PackageIdentifier. So verify each declared package is
# present and fail only on a genuinely missing one.
$missing = @()
try {
  $ids = (Get-Content $manifest -Raw | ConvertFrom-Json).Sources[0].Packages | ForEach-Object { $_.PackageIdentifier }
  foreach ($id in $ids) {
    & $winget list --id $id --exact --disable-interactivity --accept-source-agreements | Out-Null
    if ($LASTEXITCODE -ne 0) { $missing += $id }
  }
} catch {
  Write-Warning "Could not verify installed packages: $($_.Exception.Message)"
}
if ($missing.Count -gt 0) {
  Write-Warning ("Declared winget packages not installed (import exit " + $importExit + "): " + ($missing -join ', '))
  exit 1
}
if ($importExit -ne 0 -and $importExit -ne -1978335189) {
  Write-Host ("winget import exit " + $importExit + ", but all declared packages are present (a package in use could not be reinstalled).")
}
exit 0
