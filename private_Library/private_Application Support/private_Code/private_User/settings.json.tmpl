{
  "$schema": "vscode://schemas/settings/user",

  // Appearance
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.preferredDarkColorTheme": "Catppuccin Mocha",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "catppuccin.accentColor": "blue",
  "catppuccin.extraBordersEnabled": true,

  // Editor
  "editor.fontFamily": "'PragmataPro VF Mono Liga', 'Symbols Nerd Font Mono', monospace",
  "editor.fontWeight": "500",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.minimap.enabled": false,
  "editor.linkedEditing": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.stickyScroll.maxLineCount": 10,
  "diffEditor.ignoreTrimWhitespace": false,
  // Non-Liga so code ligatures don't fire inside prose.
  "markdown.preview.fontFamily": "'PragmataPro VF', sans-serif",
  "workbench.editor.closeEmptyGroups": false,
  "workbench.editor.tabSizing": "shrink",

  // Files
  "files.associations": {
    "**/zed/*.json": "jsonc"
  },
  // Keep the file watcher out of nested .worktrees/<name> checkouts.
  "files.watcherExclude": {
    "**/.worktrees/**": true
  },

  // Terminal
  "terminal.integrated.defaultProfile.osx": "nu",
  "terminal.integrated.fontSize": 14,
  // Off — webgl/canvas renderers often corrupt the TUI buffer in long sessions.
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.profiles.osx": {
    "nu": {
      "path": "nu",
      "icon": "terminal"
    },
    "zsh": {
      "path": "zsh",
      "icon": "terminal"
    },
    "claude": {
      "path": "claude",
      "icon": "sparkle"
    }
  },
  // Disabled — hover popup is slow to appear and lingers until re-hovered. Cmd-click still works.
  "terminal.integrated.showLinkHover": false,

  // Privacy
  "redhat.telemetry.enabled": false,
  "telemetry.telemetryLevel": "off",
  "chat.disableAIFeatures": true,

  // Nix
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      }
    }
  },

  // Trust
  "json.schemaDownload.trustedDomains": {
    "https://biomejs.dev": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://esm.sh": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true
  },

{{ range $layer := .layerList -}}
{{ range $root := list "modules" "overlays" -}}
{{ $fragment := joinPath $.chezmoi.homeDir ".config/nix-darwin" $root $layer "vscode-settings.jsonc" -}}
{{ if stat $fragment }}{{ output "cat" $fragment }}{{ end -}}
{{ end -}}
{{ end }}
  // Activity Bar
  "workbench.activityBar.compact": true,
  "workbench.activityBar.location": "top",

  // Git
  "git.autofetch": true,
  "git.confirmSync": false,
  // List nested .worktrees/<name> checkouts as their own repos in Source Control.
  "git.detectWorktrees": true
}
