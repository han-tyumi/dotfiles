[
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\\\r\n" },
    "when": "terminalFocus"
  },
  {
    "key": "cmd+;",
    "command": "claude-vscode.blur",
    "when": "!config.claudeCode.useTerminal && !editorTextFocus"
  },
  {
    "key": "cmd+escape",
    "command": "-claude-vscode.blur",
    "when": "!config.claudeCode.useTerminal && !editorTextFocus"
  },
  {
    "key": "cmd+;",
    "command": "claude-vscode.focus",
    "when": "editorTextFocus && !config.claudeCode.useTerminal"
  },
  {
    "key": "cmd+escape",
    "command": "-claude-vscode.focus",
    "when": "editorTextFocus && !config.claudeCode.useTerminal"
  }
]
