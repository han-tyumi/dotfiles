#!/bin/bash

# {{ include "dot_config/mise/config.toml" | sha256sum }}
{{- range .layerList }}
{{- $fragment := printf "dot_config/mise/conf.d/%s.toml" . }}
{{- $fragmentTmpl := printf "dot_config/mise/conf.d/%s.toml.tmpl" . }}
{{- if stat (joinPath $.chezmoi.sourceDir $fragment) }}
# {{ include $fragment | sha256sum }}
{{- else if stat (joinPath $.chezmoi.sourceDir $fragmentTmpl) }}
# {{ include $fragmentTmpl | sha256sum }}
{{- end }}
{{- end }}

# Mid-bootstrap shells don't have the Homebrew-installed mise on PATH yet.
export PATH="/opt/homebrew/bin:$PATH"

mise plugins upgrade
mise upgrade

# Backend tools (npm:, pipx:) resolve through runtimes declared in the same
# config, which don't exist yet on a fresh machine: a lenient first pass
# installs the runtimes, the strict second pass gets the rest.
mise install || true
mise install
