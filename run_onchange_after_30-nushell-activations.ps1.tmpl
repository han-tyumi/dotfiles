# nushell activations hash: {{ include "dot_config/winget/packages.json" | sha256sum }}
#
# Generate nushell's mise/starship/zoxide activation modules. Nushell resolves
# `source` at parse time, so config.nu sources these unconditionally and they
# must exist before the first nushell launch; chezmoi runs this during the same
# apply (after the winget + mise scripts), and the create_*.nu stubs guarantee
# the files exist even before this runs. Kept PowerShell 5.1-safe for the first
# apply (no pwsh 7 yet).

# winget updates PATH in the registry but not this session; fold the Machine +
# User registry PATH in so installer packages (nu) and package-root exes
# (starship, zoxide) resolve during this same apply.
$machinePath = [Environment]::GetEnvironmentVariable('Path', 'Machine')
$userPath = [Environment]::GetEnvironmentVariable('Path', 'User')
$env:PATH = "$machinePath;$userPath;$env:PATH"

$nushellDir = Join-Path $env:APPDATA 'nushell'
if (-not (Test-Path $nushellDir)) { New-Item -ItemType Directory -Path $nushellDir | Out-Null }

# Write UTF-8 without a BOM; nushell chokes on a leading BOM in a sourced file
# (Set-Content -Encoding UTF8 emits one under PowerShell 5.1).
$utf8NoBom = New-Object System.Text.UTF8Encoding($false)

function Write-NuActivation($exe, $activateArgs, $outFile, $exePath) {
  $target = Join-Path $nushellDir $outFile
  $cmd = if ($exePath -and (Test-Path $exePath)) { $exePath } else { (Get-Command $exe -ErrorAction SilentlyContinue).Source }
  if ($cmd) {
    $content = (& $cmd @activateArgs | Out-String)
    [System.IO.File]::WriteAllText($target, $content, $utf8NoBom)
    Write-Host "Generated $outFile"
  } else {
    [System.IO.File]::WriteAllText($target, "# $exe not found; activation skipped until it is installed.`n", $utf8NoBom)
    Write-Warning "$exe not found; wrote an empty $outFile so nushell startup still parses."
  }
}

# mise installs into a bin subdirectory of its winget package. Even after that dir
# is folded onto PATH above, Get-Command does not resolve mise during a chezmoi
# apply (it does interactively), so resolve the exe from its known install location
# and pass it to Write-NuActivation to invoke by full path instead of a PATH lookup.
# GetFolderPath is used for the base so it holds even if the LOCALAPPDATA env var
# is absent.
$localApp = [Environment]::GetFolderPath('LocalApplicationData')
$miseExe = Get-ChildItem (Join-Path $localApp 'Microsoft\WinGet\Packages\jdx.mise_*\mise\bin\mise.exe') -ErrorAction SilentlyContinue |
  Sort-Object FullName | Select-Object -Last 1 -ExpandProperty FullName

Write-NuActivation 'mise' @('activate', 'nu') 'mise.nu' $miseExe
Write-NuActivation 'starship' @('init', 'nu') 'starship.nu'
Write-NuActivation 'zoxide' @('init', 'nushell') 'zoxide.nu'
