# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}
{{- range .layerList }}
{{- $fragment := printf "dot_config/mise/conf.d/%s.toml" . }}
{{- $fragmentTmpl := printf "dot_config/mise/conf.d/%s.toml.tmpl" . }}
{{- if stat (joinPath $.chezmoi.sourceDir $fragment) }}
# {{ include $fragment | sha256sum }}
{{- else if stat (joinPath $.chezmoi.sourceDir $fragmentTmpl) }}
# {{ include $fragmentTmpl | sha256sum }}
{{- end }}
{{- end }}
#
# Install the mise-managed runtimes from the shared config (the same config.toml
# the Mac uses). The winget package installs the mise binary into a bin
# subdirectory of its package (...\WinGet\Packages\jdx.mise_*\mise\bin\mise.exe).
# That dir is on the User registry PATH but not necessarily this apply session,
# and the winget import that ran just above churns the PATH while it works, so
# resolve the exe directly from its install location and fall back to PATH only
# for a mise installed some other way. Two passes: backend tools (npm:, pipx:)
# resolve through runtimes declared in the same file, which do not exist on the
# first pass. The personal layer's Windows-unbuildable runtimes (crystal, erlang,
# elixir) are gated out of conf.d/personal.toml on Windows, so a clean install is
# expected here.
$mise = Get-ChildItem "$env:LOCALAPPDATA\Microsoft\WinGet\Packages\jdx.mise_*\mise\bin\mise.exe" -ErrorAction SilentlyContinue |
  Sort-Object FullName | Select-Object -Last 1 -ExpandProperty FullName
if (-not $mise) { $mise = (Get-Command mise -ErrorAction SilentlyContinue).Source }
if (-not $mise) {
  # Non-zero exit so chezmoi re-fires this on the next apply instead of recording
  # the run_onchange as done with nothing installed.
  Write-Warning "mise not found after the winget install; run 'mise install' in a new shell."
  exit 1
}
& $mise install 2>&1 | Out-Null
& $mise install
if ($LASTEXITCODE -ne 0) {
  Write-Warning "mise install reported errors - a declared runtime may lack a Windows build. Check the output above."
}
exit 0
