{{ if stat "/opt/homebrew/bin/code" -}}
#!/bin/bash
{{- $ids := list }}
{{- range $layer := concat (list "shared") .layerList }}
{{-   range $root := list "modules" "overlays" }}
{{-     $file := joinPath $.chezmoi.homeDir ".config/nix-darwin" $root $layer "vscode-extensions.txt" }}
{{-     if stat $file }}
{{-       range $line := splitList "\n" (include $file) }}
{{-         $line = trim $line }}
{{-         if and $line (not (hasPrefix "#" $line)) }}
{{-           $ids = append $ids (lower $line) }}
{{-         end }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

set -euo pipefail

# Mid-bootstrap shells don't have the Homebrew-installed code on PATH yet.
export PATH="/opt/homebrew/bin:$PATH"

# The `code` CLI bundles a Node that emits a url.parse() deprecation warning
# (DEP0169) on every marketplace fetch — VS Code's noise, not ours. Mute it;
# real install errors still go to stderr.
export NODE_NO_WARNINGS=1

# The union of every enabled layer's vscode-extensions.txt, rendered in by
# chezmoi so the script re-runs whenever the effective id set changes.
wanted=$(cat <<'EOF'
{{ range sortAlpha (uniq $ids) -}}
{{ . }}
{{ end -}}
EOF
)

# Failures warn instead of blocking the apply: a yanked id or a marketplace
# outage shouldn't wedge provisioning. Skipped installs retry on the next
# list change.
if ! installed=$(code --list-extensions </dev/null | tr '[:upper:]' '[:lower:]' | LC_ALL=C sort -u); then
  echo "vscode-extensions: 'code --list-extensions' failed; skipping" >&2
  exit 0
fi

failed=""
while IFS= read -r ext; do
  echo "vscode-extensions: installing $ext"
  code --install-extension "$ext" </dev/null >/dev/null || failed="$failed $ext"
done < <(comm -23 <(printf '%s\n' "$wanted") <(printf '%s\n' "$installed"))

if [ -n "$failed" ]; then
  echo "vscode-extensions: failed to install:$failed" >&2
fi

# Install-only: report drift, never uninstall.
extras=$(comm -13 <(printf '%s\n' "$wanted") <(printf '%s\n' "$installed"))
if [ -n "$extras" ]; then
  echo "vscode-extensions: installed but not in any layer list:" >&2
  sed 's/^/  /' <<<"$extras" >&2
fi
{{ end -}}
