{{ range $name, $url := .enabledOverlays -}}
# Overlay layers clone next to the flake, which imports their modules when the
# layer is enabled. Not shallow: the clone doubles as the editing working copy.
[".config/nix-darwin/overlays/{{ $name }}"]
type = "git-repo"
url = "{{ $url }}"
# Refresh at most once a day so a pushed overlay change lands on a plain
# apploi within a day (the clone is small and the pull is ff-only). A bare
# `apploi -R` forces it — and the heavier externals — immediately.
refreshPeriod = "24h"
pull.args = ["--ff-only"]

{{ end -}}
