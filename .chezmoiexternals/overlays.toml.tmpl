{{ range $name, $url := .enabledOverlays -}}
# Overlay layers clone next to the flake, which imports their modules when the
# layer is enabled. Not shallow: the clone doubles as the editing working copy.
[".config/nix-darwin/overlays/{{ $name }}"]
type = "git-repo"
url = "{{ $url }}"
# Refresh on every apply so a pushed overlay change lands on plain apploi; the
# clone is small and the pull is ff-only. `apploi -R` additionally forces the
# heavier, rarely-changing externals (V, Roc, nu_scripts) on demand.
refreshPeriod = "0"
pull.args = ["--ff-only"]

{{ end -}}
