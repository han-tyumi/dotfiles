# Ghostty configuration.
# Reference: https://ghostty.org/docs/config/reference

# Primary: PragmataPro's no-ligature, grid-monospaced VF face — byte fidelity for
# logs/diffs, and the same VF family-set the editor uses. Falls back per-codepoint
# to Iosevka Nerd Font Mono, a condensed PragmataPro-like coding face with letters
# + icons, so a machine without PragmataPro still renders text and glyphs.
font-family = PragmataPro VF Mono
font-family = Iosevka Nerd Font Mono
font-family = Menlo
font-size = 14

# Ligatures off (terminal = byte fidelity). calt gates programming ligatures;
# liga/dlig cover standard/discretionary. Applies to every font in the chain.
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# Thicken glyph stems to match the heavier weight CoreText renders at (macOS only).
font-thicken = true

theme = Catppuccin Mocha

# Inset the grid so the first column clears the window controls, and spread
# the leftover sub-cell space evenly across all four edges.
window-padding-x = 10
window-padding-balance = true

# nushell is the interactive shell; the login zsh assembles the Nix/Homebrew
# environment it inherits.
command = /bin/zsh -lc nu
