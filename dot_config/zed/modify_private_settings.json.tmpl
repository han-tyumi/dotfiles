#!/usr/bin/env python3
# chezmoi modify_ script: merge the managed Zed settings over the live file,
# preserving Zed-written UI state (dock positions, favorite models, ...) that a
# plain managed file would revert on every apply. Managed keys win; keys present
# only in the live file are kept. Removals in the managed set don't propagate
# (edit the live file to drop a key). Output is plain JSON — Zed reads it fine;
# the documented comments live in the managed template (.chezmoitemplates/zed-settings.json).
import sys, json, re

MANAGED = r'''
{{ template "zed-settings.json" . }}
'''


def load(text):
    text = re.sub(r'(?m)^[ \t]*//.*$', '', text)  # strip full-line // comments
    text = re.sub(r',(\s*[}\]])', r'\1', text)     # strip trailing commas
    return json.loads(text) if text.strip() else {}


def merge(base, over):
    for key, value in over.items():
        if isinstance(base.get(key), dict) and isinstance(value, dict):
            merge(base[key], value)
        else:
            base[key] = value
    return base


live = load(sys.stdin.read())
managed = load(MANAGED)
json.dump(merge(live, managed), sys.stdout, indent=2)
sys.stdout.write("\n")
