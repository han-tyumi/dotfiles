// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "$schema": "zed://schemas/settings",

  // Appearance
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_family": "Iosevka Aile",
  "ui_font_size": 16,
  "buffer_font_family": "Iosevka",
  "buffer_font_fallbacks": ["Symbols Nerd Font Mono"],
  "buffer_font_weight": 500,
  "buffer_font_size": 15,

  // Languages
  "languages": {
    // Iosevka's JavaScript ligation set adds === and !== ligatures.
    "TypeScript": {
      "buffer_font_features": { "JSPT": true },
    },
    "TSX": {
      "buffer_font_features": { "JSPT": true },
    },
    "JavaScript": {
      "buffer_font_features": { "JSPT": true },
    },
  },

  // Terminal
  // Nushell is the interactive shell; the login zsh assembles the
  // nix/Homebrew environment it inherits.
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": ["-lc", "nu"],
      },
    },
  },

  // Key Bindings
  "base_keymap": "VSCode",

  // Agent
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },

  // Extensions
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "nu": true,
  },
}
