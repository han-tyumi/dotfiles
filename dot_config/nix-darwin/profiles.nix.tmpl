# Generated by chezmoi from its config data; edit via `chezmoi init --promptBool personal=…,work=…`.
{
  # darwin-rebuild selects the flake attr via `scutil --get LocalHostName`,
  # which differs from chezmoi's .chezmoi.hostname.
  hostname = "{{ output "scutil" "--get" "LocalHostName" | trim }}";
  username = "{{ .chezmoi.username }}";
  personal = {{ .personal }};
  work = {{ .work }};
}
