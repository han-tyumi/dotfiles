#!/bin/bash

# {{ include "dot_config/terminal/catppuccin-mocha.terminal" | sha256sum }}

# The profile's colors come from https://github.com/catppuccin/Terminal.app
# (catppuccin-mocha), with the font set to Iosevka Term Medium.
#
# Install the Terminal.app profile. Terminal rewrites its preferences on
# quit, so quit it before applying changes to this profile.
# To capture in-app tweaks back into chezmoi:
#   defaults export com.apple.Terminal - \
#     | plutil -extract 'Window Settings.catppuccin-mocha' xml1 -o - - \
#     > "$(chezmoi source-path)/dot_config/terminal/catppuccin-mocha.terminal"

# Only the profile dict imports here; the plain com.apple.Terminal keys
# (default/startup profile selection, the nushell shell command) are set
# declaratively in nix-darwin's CustomUserPreferences.
profile="$HOME/.config/terminal/catppuccin-mocha.terminal"
defaults write com.apple.Terminal "Window Settings" -dict-add "catppuccin-mocha" "$(cat "$profile")"
