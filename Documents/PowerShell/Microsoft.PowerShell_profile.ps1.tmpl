# PowerShell 7 profile — mirrors the Mac shell (mise + starship + zoxide) and
# defines `apploi` for one-command sync. Managed by chezmoi.
#
# Note: if OneDrive Known Folder redirection is on, "Documents" resolves under
# %USERPROFILE%\OneDrive\Documents and this file must live there instead.

# mise: shims + env for this shell.
if (Get-Command mise -ErrorAction SilentlyContinue) {
  (& mise activate pwsh | Out-String) | Invoke-Expression
}

# starship prompt.
if (Get-Command starship -ErrorAction SilentlyContinue) {
  (& starship init powershell | Out-String) | Invoke-Expression
}

# zoxide (`z <dir>` to jump).
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
  (& zoxide init powershell | Out-String) | Invoke-Expression
}

# fzf key bindings via PSFzf: Ctrl+T (files), Ctrl+R (fuzzy history). Installed by
# run_once_after_70-psfzf; imported here only when the module is present.
if (Get-Module -ListAvailable -Name PSFzf) {
  Import-Module PSFzf
  Set-PsFzfOption -PSReadlineChordProvider 'Ctrl+t' -PSReadlineChordReverseHistory 'Ctrl+r'
}

# One-command sync, mirroring the Mac `apploi`:
#   apploi      converge to the declared dotfiles + package state
#   apploi -u   also upgrade winget packages and mise plugins + runtimes
# (On the Mac, -u updates the nix-darwin flake inputs; Windows has no flake, so
# here it means the package/runtime upgrade a plain Mac apploi does every run.)
# Each step prints a line so a converged (no-op) run still confirms it ran.
function apploi {
  param([switch] $Upgrade)

  $source = chezmoi source-path

  # Consumer machines stay current through plain apploi; a dirty tree (mid-edit)
  # skips the pull so local changes aren't disturbed. Ignore a dirty submodule so
  # the perpetually-dirty nvim submodule doesn't block the pull every run.
  git -C $source diff --quiet --ignore-submodules=dirty HEAD
  if ($LASTEXITCODE -eq 0) {
    Write-Host 'apploi: pulling dotfiles source...' -ForegroundColor Cyan
    git -C $source pull --ff-only --quiet
    if ($LASTEXITCODE -ne 0) {
      Write-Host 'apploi: pull skipped — origin diverged; resync with: git fetch && git reset --hard origin/main' -ForegroundColor Yellow
    }
  } else {
    Write-Host 'apploi: local changes present — skipping pull' -ForegroundColor Cyan
  }

  # --keep-going so one failing target doesn't skip every later target.
  Write-Host 'apploi: applying dotfiles...' -ForegroundColor Cyan
  chezmoi apply --keep-going

  if ($Upgrade) {
    Write-Host 'apploi: upgrading winget packages...' -ForegroundColor Cyan
    winget upgrade --all --silent --include-unknown --accept-package-agreements --accept-source-agreements --disable-interactivity
    Write-Host 'apploi: upgrading mise plugins and runtimes...' -ForegroundColor Cyan
    mise plugins upgrade
    mise upgrade

    # Regenerate nushell's activation modules against the upgraded tools: the
    # provisioner that writes them is keyed on packages.json, which an upgrade
    # doesn't touch. (pwsh re-runs its own activations at every start.)
    if (Get-Command nu -ErrorAction SilentlyContinue) {
      nu -c '^mise activate nu | save -f ($nu.default-config-dir | path join mise.nu)'
      nu -c '^starship init nu | save -f ($nu.default-config-dir | path join starship.nu)'
      nu -c '^zoxide init nushell | save -f ($nu.default-config-dir | path join zoxide.nu)'
    }
  }

  # Surface a WinUtil update if the pinned build is behind (best-effort, quiet when current).
  $winutilMgr = Join-Path $HOME '.config\winutil\manage.ps1'
  if (Test-Path $winutilMgr) { try { & $winutilMgr } catch { } }

  Write-Host 'apploi: done.' -ForegroundColor Green
}
