{{ if lookPath "agent-browser" -}}
#!/bin/bash

# {{ output "agent-browser" "--version" | trim }}

set -euo pipefail

# Mid-bootstrap shells don't have the Homebrew-installed agent-browser on PATH yet.
export PATH="/opt/homebrew/bin:$PATH"

# Download the Chrome for Testing build the agent-browser daemon drives. The
# command skips the download when a matching browser is already present, and the
# version comment above re-triggers this script after an upgrade so the browser
# tracks the CLI. Without a downloaded (or system) Chrome, agent-browser errors
# on first use.
agent-browser install
{{ end -}}
