{{- /* Prompt text doubles as the --promptString key, e.g.
`chezmoi init --promptString "layers=personal work,overlays=work=git@github.com:user/repo.git"`.
Both prompts are space-separated; overlays entries are name=url pairs. */ -}}
{{- $layers := promptStringOnce . "layers" "layers" -}}
{{- $overlays := promptStringOnce . "overlays" "overlays" -}}
{{- $layerList := splitList " " $layers | compact -}}

encryption = "age"
[age]
  identity = "{{ .chezmoi.homeDir }}/key.txt"
  recipient = "age1zf3ruadchuuxhhc0sq96fdn5gazryegnfprwncrprylzqt2ce3aqzm5ekc"
[cd]
  command = "zsh"
  args = ["-lc", "nu"]
[data]
  layers = {{ $layers | quote }}
  overlays = {{ $overlays | quote }}
  layerList = [{{ range $index, $layer := $layerList }}{{ if $index }}, {{ end }}{{ $layer | quote }}{{ end }}]

{{- /* Declared overlays filtered to enabled layers: the single source for both
bootstrap cloning and the chezmoi external. */}}
[data.enabledOverlays]
{{- range splitList " " $overlays | compact }}
{{- $pair := splitn "=" 2 . }}
{{- if has $pair._0 $layerList }}
  {{ $pair._0 }} = {{ $pair._1 | quote }}
{{- end }}
{{- end }}
